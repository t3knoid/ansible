#!/bin/sh
set -eu

CHAIN="{{ openvpn_setup_firewall_chain }}"
CHAIN_V6="{{ openvpn_setup_firewall_chain_v6 }}"
VPN_IF="{{ openvpn_setup_interface }}"
VPN_REMOTE="{{ openvpn_setup_remote_address | default(openvpn_setup_remote_server) }}"
VPN_REMOTE_V6="{{ openvpn_setup_remote_address_v6 | default('') }}"
VPN_PORT="{{ openvpn_setup_remote_port }}"
VPN_PROTO="{{ openvpn_setup_remote_protocol }}"
ACTION="${1:-apply}"

remove_rules() {
  iptables -D OUTPUT -j "$CHAIN" 2>/dev/null || true
  iptables -F "$CHAIN" 2>/dev/null || true
  iptables -X "$CHAIN" 2>/dev/null || true
  ip6tables -D OUTPUT -j "$CHAIN_V6" 2>/dev/null || true
  ip6tables -F "$CHAIN_V6" 2>/dev/null || true
  ip6tables -X "$CHAIN_V6" 2>/dev/null || true
}

apply_rules() {
  iptables -N "$CHAIN" 2>/dev/null || true
  iptables -F "$CHAIN"
  iptables -A "$CHAIN" -o lo -j ACCEPT
  iptables -A "$CHAIN" -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
  iptables -A "$CHAIN" -o "$VPN_IF" -j ACCEPT
  iptables -A "$CHAIN" -d "$VPN_REMOTE" -p "$VPN_PROTO" --dport "$VPN_PORT" -j ACCEPT
{% for cidr in openvpn_setup_firewall_exempt_cidrs %}
  iptables -A "$CHAIN" -d "{{ cidr }}" -j ACCEPT
{% endfor %}
  iptables -A "$CHAIN" -j REJECT
  iptables -C OUTPUT -j "$CHAIN" 2>/dev/null || iptables -I OUTPUT 1 -j "$CHAIN"

  ip6tables -N "$CHAIN_V6" 2>/dev/null || true
  ip6tables -F "$CHAIN_V6"
  ip6tables -A "$CHAIN_V6" -o lo -j ACCEPT
  ip6tables -A "$CHAIN_V6" -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
  ip6tables -A "$CHAIN_V6" -o "$VPN_IF" -j ACCEPT
  if [ -n "$VPN_REMOTE_V6" ]; then
    ip6tables -A "$CHAIN_V6" -d "$VPN_REMOTE_V6" -p "$VPN_PROTO" --dport "$VPN_PORT" -j ACCEPT
  fi
{% for cidr in openvpn_setup_firewall_exempt_cidrs_v6 %}
  ip6tables -A "$CHAIN_V6" -d "{{ cidr }}" -j ACCEPT
{% endfor %}
  ip6tables -A "$CHAIN_V6" -j REJECT
  ip6tables -C OUTPUT -j "$CHAIN_V6" 2>/dev/null || ip6tables -I OUTPUT 1 -j "$CHAIN_V6"
}

case "$ACTION" in
  apply)
    apply_rules
    ;;
  remove)
    remove_rules
    ;;
  *)
    echo "Usage: $0 [apply|remove]" >&2
    exit 2
    ;;
esac