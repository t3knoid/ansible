
# Ansible generated on {{ ansible_date_time.date }} at {{ ansible_date_time.time }}
# See https://prometheus.io/docs/prometheus/latest/configuration/configuration/
# for more details.

global:
  scrape_interval:     15s # By default, scrape targets every 15 seconds.

  # Attach these labels to any time series or alerts when communicating with
  # external systems (federation, remote storage, Alertmanager).
  external_labels:
    monitor: 'codelab-monitor'

rule_files:
  - 'prometheus.rules.yml'

# A scrape configuration containing exactly one endpoint to scrape:
# Here it's Prometheus itself.
scrape_configs:
  # The job name is added as a label `job=<job_name>` to any timeseries scraped from this config.
  - job_name: 'prometheus'

    # Override the global default and scrape targets from this job every 5 seconds.
    scrape_interval: 5s

    static_configs:
      - targets: ['{{ global_ip_addresses[ansible_host] }}:9090']

{% if prometheus_setup_node_static_configs is defined %}
{% if prometheus_setup_node_static_configs | length > 0 %}
  - job_name: 'node'
    scrape_interval: 5s

    static_configs:
{% for scrape_config in prometheus_setup_node_static_configs %}
      - targets: {{ scrape_config.targets | to_json }}
        labels:
          instance: '{{ scrape_config.labels.instance }}'
          group: '{{ scrape_config.labels.group }}'
{% endfor %}
{% endif %}
{% elif groups['node_exporter'] | default([]) | length > 0 %}
  - job_name: 'node'
    scrape_interval: 5s

    static_configs:
{% for host in groups['node_exporter'] %}
      - targets: ['{{ global_ip_addresses[host] }}:{{ hostvars[host].node_exporter_port }}']
        labels:
          instance: {{ host }}
          group: {{ host | regex_replace('-[0-9]+$', '') }}
{% endfor %}
{% endif %}

{% if prometheus_setup_nginx_exporter_static_configs is defined %}
{% if prometheus_setup_nginx_exporter_static_configs | length > 0 %}
  - job_name: 'nginx_exporter'
    scrape_interval: 5s

    static_configs:
{% for scrape_config in prometheus_setup_nginx_exporter_static_configs %}
      - targets: {{ scrape_config.targets | to_json }}
        labels:
          instance: '{{ scrape_config.labels.instance }}'
          group: '{{ scrape_config.labels.group }}'
{% endfor %}
{% endif %}
{% elif groups['nginx_exporter'] | default([]) | length > 0 %}
  - job_name: 'nginx_exporter'
    scrape_interval: 5s

    static_configs:
{% for host in groups['nginx_exporter'] %}
      - targets: ['{{ global_ip_addresses[host] }}:{{ hostvars[host].nginx_prometheus_exporter_port }}']
        labels:
          instance: {{ host }}
          group: {{ host | regex_replace('-[0-9]+$', '') }}
{% endfor %}
{% endif %}
