          "mode": "single",
          "sort": "none"
        }
      },
      "pluginVersion": "12.2.0",
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by(instance) (rate(pg_stat_database_xact_commit{job=\"postgres_exporter\",datname!~\"template0|template1\"}[5m]) + rate(pg_stat_database_xact_rollback{job=\"postgres_exporter\",datname!~\"template0|template1\"}[5m]))",
          "legendFormat": "{{instance}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Transactions per Second",
      "type": "timeseries"
