        {
          "editorMode": "code",
          "expr": "(2 * (up{job=\"node\"} == 1)) or (1 * ((up{job=\"node\"} == 0) and on(instance) (sum by(instance) (present_over_time(node_time_seconds{job=\"node\"}[5m])) > 0))) or (0 * ((up{job=\"node\"} == 0) unless on(instance) (sum by(instance) (present_over_time(node_time_seconds{job=\"node\"}[5m])) > 0)))",
          "instant": true,
          "legendFormat": "{{instance}}",
          "range": false,
          "refId": "A"
        }
      ],
